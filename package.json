{
  "name": "@cls-bolivar/mcp-front-migrate",
  "version": "1.4.0",
  "description": "MCP Server para migración de micro-frontends React → Angular CLS con pipeline completo + ML optimizer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ml": {
      "types": "./dist/ml/optimizer.d.ts",
      "import": "./dist/ml/optimizer.js"
    }
  },
  "bin": {
    "cls-migrate": "dist/commands.js",
    "mcp-front-migrate": "dist/cli.js",
    "cls-front-migrate": "dist/stdio-server.js",
    "cls-front-migrate-http": "dist/http-server.js",
    "cls-migrate-project": "dist/migrate-cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js.map",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "start": "node dist/stdio-server.js",
    "start:http": "node dist/http-server.js",
    "test": "vitest --run",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "react",
    "angular",
    "migration",
    "micro-frontend",
    "primeng",
    "cls",
    "seguros-bolivar",
    "ml",
    "auto-fix",
    "code-generation",
    "typescript",
    "signals"
  ],
  "author": "CLS Bolivar",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cls-bolivar/mcp-front-migrate.git"
  },
  "homepage": "https://github.com/cls-bolivar/mcp-front-migrate#readme",
  "bugs": {
    "url": "https://github.com/cls-bolivar/mcp-front-migrate/issues"
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.29.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@octokit/rest": "^21.1.1",
    "commander": "^13.1.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^25.6.0",
    "fast-check": "^3.23.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
