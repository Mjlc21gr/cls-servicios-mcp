{
  "name": "@cls-bolivar/mcp-front-migrate",
  "version": "1.1.0",
  "description": "MCP Server para migración de micro-frontends React → Angular CLS con pipeline completo",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-front-migrate": "dist/cli.js",
    "cls-front-migrate": "dist/stdio-server.js",
    "cls-front-migrate-http": "dist/http-server.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "README.md"
  ],
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/stdio-server.js",
    "start:http": "node dist/http-server.js",
    "test": "vitest --run",
    "dev": "ts-node --esm src/stdio-server.ts",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "react",
    "angular",
    "migration",
    "micro-frontend",
    "primeng",
    "cls",
    "seguros-bolivar"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cls-bolivar/mcp-front-migrate.git"
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "@babel/traverse": "^7.27.0",
    "@babel/types": "^7.29.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@octokit/rest": "^21.1.1",
    "commander": "^13.1.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^25.6.0",
    "fast-check": "^3.23.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
